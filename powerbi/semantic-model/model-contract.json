  "tables": {
    "fact_operational_item": {
      "grain": "One row per operational work item",
      "source": "data/sample-operational-data.csv",
      "columns": [
        "item_id",
        "item_reference",
        "opened_date",
        "due_date",
        "closed_date",
        "reporting_period",
        "service_area_id",
        "owner_id",
        "category_id",
