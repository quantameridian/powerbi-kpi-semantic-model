        "priority",
        "target_key",
        "evidence_status",
        "closure_evidence_link",
        "review_flag",
        "notes"
      ]
    },
    "fact_target": {
      "grain": "One row per category, priority, and target key",
      "source": "data/sample-targets.csv",
      "columns": [
        "target_key",
        "target_id",
        "category_id",
        "priority",
        "target_days",
        "target_met_rate",
        "effective_from",
        "effective_to",
        "target_owner_role",
        "notes"
      ]
    },
    "dim_date": {
      "grain": "One row per calendar date",
      "source": "Generated during Power BI Desktop build",
      "columns": ["date", "year", "month_number", "month_name", "month_start_date", "reporting_period"]
    },
    "dim_service_area": {
      "grain": "One row per service area reference value",
      "source": "data/sample-reference-data.csv where reference_type = service_area",
      "columns": ["service_area_id", "service_area_name", "active_flag", "sort_order"]
    },
    "dim_owner": {
      "grain": "One row per owner reference value",
      "source": "data/sample-reference-data.csv where reference_type = owner",
      "columns": ["owner_id", "owner_name", "service_area_id", "active_flag", "sort_order"]
    },
    "dim_category": {
      "grain": "One row per category reference value",
      "source": "data/sample-reference-data.csv where reference_type = category",
      "columns": ["category_id", "category_name", "service_area_id", "active_flag", "sort_order"]
    },
    "dim_status": {
      "grain": "One row per status reference value",
      "source": "data/sample-reference-data.csv where reference_type = status",
      "columns": ["status", "status_name", "active_flag", "sort_order"]
    },
    "dim_priority": {
      "grain": "One row per priority reference value",
      "source": "data/sample-reference-data.csv where reference_type = priority",
      "columns": ["priority", "priority_name", "active_flag", "sort_order"]
    }
  },
  "relationships": [
    {"from": "dim_service_area.service_area_id", "to": "fact_operational_item.service_area_id", "cardinality": "one_to_many", "filter_direction": "single"},
    {"from": "dim_owner.owner_id", "to": "fact_operational_item.owner_id", "cardinality": "one_to_many", "filter_direction": "single"},
    {"from": "dim_category.category_id", "to": "fact_operational_item.category_id", "cardinality": "one_to_many", "filter_direction": "single"},
    {"from": "dim_status.status", "to": "fact_operational_item.status", "cardinality": "one_to_many", "filter_direction": "single"},
    {"from": "dim_priority.priority", "to": "fact_operational_item.priority", "cardinality": "one_to_many", "filter_direction": "single"},
    {"from": "fact_target.target_key", "to": "fact_operational_item.target_key", "cardinality": "one_to_many_lookup", "filter_direction": "single"},
    {"from": "dim_date.date", "to": "fact_operational_item.opened_date", "cardinality": "one_to_many", "filter_direction": "single"}
